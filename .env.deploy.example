# ─────────────────────────────────────────────────────────────────────────────
# Wain production env. On the server:  cp .env.deploy.example .env  then edit.
# docker-compose reads .env automatically.  NEVER commit the real .env.
#
# Deploy is ONE command:   docker compose up -d --build
# (builds, starts, and seeds the database in the same command)
# ─────────────────────────────────────────────────────────────────────────────

# ── Port ──
# The ONLY host port published. Pick anything free on your server (avoids the
# busy 80/443/3000/5432). The whole app is served here over plain HTTP.
HTTP_PORT=8787

# ── Admin obscure URL ──
# The admin panel is reachable ONLY at http://HOST:HTTP_PORT<ADMIN_BASE_PATH>.
# Change this to your own random string and bookmark it. Must start with "/".
ADMIN_BASE_PATH=/console-7k29qz

# ── Public URLs (baked into web + admin at build; must match how you reach it) ──
# Use your server's IP or hostname + the port above. No trailing slash.
NEXT_PUBLIC_API_URL=http://YOUR_SERVER_IP:8787/api
APP_BASE_URL=http://YOUR_SERVER_IP:8787

# ── Database (Postgres runs in compose, internal-only; host = service "postgres") ──
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_to_a_strong_db_password
POSTGRES_DB=wain
DATABASE_URL=postgresql://postgres:change_me_to_a_strong_db_password@postgres:5432/wain

# ── Auth (API) — generate strong values, e.g. `openssl rand -hex 32` ──
AUTH_SECRET=change_me_long_random_secret
ADMIN_PASSWORD=change_me_admin_password

# ── Optional: which demo seeds to load (comma-separated). Leave default for all. ──
# SEED_SCRIPTS=seed-mall.mjs
